# ============================================================================
# Missive MCP — configuration (.env)
# ============================================================================
# Only MISSIVE_API_TOKEN is required. Everything else is an optional default
# that saves you (and the assistant) from repeating IDs on every call.
#
# Find these IDs in Missive: Settings > API > Resource IDs, or run `npm run setup`
# (it prints your organizations, contact books, teams, and users).
#
# This file holds a real credential and is gitignored — never commit or share it.

# --- Required ----------------------------------------------------------------
# Your personal access token. Missive: Preferences > API > Create a new token.
# (Your organization must be on the Missive Productive plan.) Looks like missive_pat-...
MISSIVE_API_TOKEN=

# --- Optional defaults -------------------------------------------------------
# Default organization. Used by org-scoped tools (labels, teams, users,
# responses, tasks, conversation updates) when you don't pass `organization`.
MISSIVE_DEFAULT_ORGANIZATION=

# Default contact book. Used by the contact tools when you don't pass
# `contact_book` (required to list or create contacts).
MISSIVE_DEFAULT_CONTACT_BOOK=

# Default team. Used when a draft / task / post / message omits `team` (e.g. to
# route new conversations to your main team). A task or custom-channel message
# that has a team also needs an organization, so set the org default too.
MISSIVE_DEFAULT_TEAM=

# Default "from" identity for drafts — the address replies are sent as. Used when
# a draft omits `from_field`. It must be one of your Missive aliases; copy it from
# Settings > API > Resource IDs > Accounts. (Email only.)
MISSIVE_DEFAULT_FROM_ADDRESS=
MISSIVE_DEFAULT_FROM_NAME=

# Default custom-channel account. Used by the advanced `missive_create_message`
# tool when you don't pass `account` (custom channels only).
MISSIVE_DEFAULT_ACCOUNT=
